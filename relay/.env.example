# Major Tom Relay Server Configuration

# WebSocket server port (iOS app connects here)
WS_PORT=4030

# Hook HTTP server port (Claude Code hooks POST here)
HOOK_PORT=4031

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Working directory for Claude Code CLI sessions
CLAUDE_WORK_DIR=/Users/you/your-project

# Authentication token for WebSocket and HTTP endpoints
# Auto-generated on first run if not set
AUTH_TOKEN=

# Comma-separated list of allowed CORS origins
# Leave empty or unset to allow all origins (default for local dev)
# Example: CORS_ORIGINS=https://your-tunnel.trycloudflare.com,http://localhost:5173
CORS_ORIGINS=

# Web Push (auto-generated on first run if not set)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Google OAuth (optional — enables Sign-in-with-Google for PWA + iOS)
# - GOOGLE_CLIENT_ID:     Web client ID used by the PWA's GIS button.
# - GOOGLE_CLIENT_ID_IOS: iOS client ID used by the native app's
#                        ASWebAuthenticationSession + PKCE flow. Optional —
#                        only set when you've created an iOS OAuth client in
#                        Google Cloud Console. ID tokens minted by Google for
#                        either client are accepted as long as their `aud`
#                        claim matches one of these two values.
# - ALLOWED_EMAIL:        Optional allowlist — only this email may sign in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID_IOS=
ALLOWED_EMAIL=
