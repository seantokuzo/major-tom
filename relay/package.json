{
  "name": "@major-tom/relay",
  "version": "0.1.0",
  "description": "Major Tom relay server — bridges iOS app to Claude Code",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && esbuild src/server.ts --bundle --platform=node --outdir=dist --format=esm --packages=external",
    "build:web": "cd ../web && npm run build",
    "build:all": "npm run build:web && npm run build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.79",
    "pino": "10.3.1",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/ws": "8.18.1",
    "esbuild": "0.25.0",
    "tsx": "4.19.4",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
