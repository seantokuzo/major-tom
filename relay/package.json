{
  "name": "@major-tom/relay",
  "version": "0.1.0",
  "description": "Major Tom relay server — bridges iOS app to Claude Code",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc && esbuild src/server.ts --bundle --platform=node --outdir=dist --format=esm --packages=external",
    "build:web": "cd ../web && npm run build",
    "build:all": "npm run build:web && npm run build",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "echo \"No tests yet\" && exit 0",
    "tunnel:setup": "bash ../tunnel/setup.sh",
    "tunnel": "bash ../tunnel/start.sh",
    "dev:remote": "npm run dev & npm run tunnel"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.79",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "jose": "^6.2.2",
    "pino": "10.3.1",
    "web-push": "^3.6.7",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/web-push": "3.6.4",
    "@types/ws": "8.18.1",
    "esbuild": "0.25.0",
    "tsx": "4.19.4",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
